{
  "name": "@octopus-synapse/profile-services",
  "version": "0.2.3",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "bun build src/main.ts --target=bun --outdir=dist",
    "format": "biome format --write .",
    "start": "bun --bun src/main.ts",
    "start:dev": "bun --bun --watch src/main.ts",
    "start:debug": "bun --bun --inspect --watch src/main.ts",
    "start:prod": "bun --bun dist/main.js",
    "lint": "biome check --write .",
    "lint:fast": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "i18n:audit": "bun run scripts/i18n-audit.ts",
    "test": "bun test src",
    "test:unit": "bun test src",
    "test:watch": "bun test src --watch",
    "test:coverage": "bun test src --coverage",
    "test:debug": "bun test src",
    "db:setup:test": "bunx prisma generate --config ./prisma.config.ts && bunx prisma migrate deploy --config ./prisma.config.ts && bun run prisma/seed.ts",
    "test:e2e": "./scripts/run-e2e.sh",
    "test:e2e:fresh": "./scripts/run-e2e.sh --fresh",
    "test:e2e:ci": "./scripts/run-e2e-ci.sh",
    "test:e2e:run": "DATABASE_URL=postgresql://postgres:postgres@localhost:5433/profile_test REDIS_HOST=localhost REDIS_PORT=6380 JWT_SECRET=e2e_test_secret_key_minimum_32_characters_long NODE_ENV=test bun test --config=bunfig.e2e.toml",
    "test:integration": "bun test --config=bunfig.integration.toml",
    "test:integration:run": "DATABASE_URL=postgresql://postgres:postgres@localhost:5433/profile_test REDIS_HOST=localhost REDIS_PORT=6380 JWT_SECRET=test_secret_key_minimum_32_characters_long NODE_ENV=test bun test --config=bunfig.integration.toml",
    "test:integration:ci": "./scripts/run-integration-ci.sh",
    "test:static": "bun test --config=bunfig.static-analysis.toml",
    "test:arch": "bun test ./test/static-analysis/architecture",
    "test:contracts": "bun test ./test/static-analysis/contracts",
    "test:security": "bun test --config=bunfig.security.toml",
    "test:fast": "bun test --bail",
    "test:watch:verbose": "bun test --watch",
    "precommit": "./.husky/pre-commit",
    "ci:lint": "bun run lint",
    "ci:test": "bun test src",
    "prisma:generate": "bunx prisma generate --config ./prisma.config.ts",
    "prisma:migrate": "bunx prisma migrate dev --config ./prisma.config.ts",
    "prisma:migrate:deploy": "bunx prisma migrate deploy --config ./prisma.config.ts",
    "prisma:push": "bunx prisma db push --config ./prisma.config.ts",
    "prisma:studio": "bunx prisma studio --config ./prisma.config.ts",
    "prisma:seed": "bun run prisma/seed.ts",
    "db:setup": "bunx prisma generate --config ./prisma.config.ts && bunx prisma migrate deploy --config ./prisma.config.ts",
    "db:reset": "bunx prisma migrate reset --config ./prisma.config.ts --force",
    "schemas:export": "bun run src/scripts/export-schemas.ts",
    "openapi:generate": "bun run src/scripts/generate-openapi.ts",
    "swagger:generate": "bun run scripts/generate-swagger-from-decorators.ts",
    "swagger:test": "bun test ./test/static-analysis/contracts/swagger-generation.contract.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^7.3.4",
    "@aws-sdk/client-s3": "^3.1021.0",
    "@elysiajs/cookie": "^0.8.0",
    "@elysiajs/cors": "^1.4.2",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "bullmq": "^5.72.0",
    "busboy": "^1.6.0",
    "croner": "^10.0.1",
    "docx": "^8.6.0",
    "elysia": "^1.4.28",
    "ioredis": "^5.10.1",
    "jose": "^6.2.3",
    "jszip": "^3.10.1",
    "mammoth": "^1.12.0",
    "multer": "^2.1.1",
    "nestjs-zod": "^5.2.1",
    "nodemailer": "^8.0.5",
    "openai": "^6.34.0",
    "passport-github2": "^0.1.12",
    "passport-linkedin-oauth2": "^2.0.0",
    "pdf-parse": "^2.4.5",
    "pino": "^10.3.1",
    "prom-client": "^15.1.3",
    "puppeteer": "^24.40.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.3",
    "speakeasy": "^2.0.0",
    "winston": "^3.19.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@commitlint/cli": "^20.5.0",
    "@faker-js/faker": "^10.4.0",
    "@octopus-synapse/biome-config": "^1",
    "@octopus-synapse/commitlint-config": "^1",
    "@octopus-synapse/precommit": "^1",
    "@octopus-synapse/release-cli": "^1.7.0",
    "@swc/cli": "^0.6.0",
    "@swc/core": "^1.15.21",
    "@types/bun": "latest",
    "@types/busboy": "^1.5.4",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.19.15",
    "@types/nodemailer": "^8.0.0",
    "@types/passport-github2": "^1.2.9",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-linkedin-oauth2": "^1.5.6",
    "@types/passport-local": "^1.0.38",
    "@types/pdf-parse": "^1.1.5",
    "@types/qrcode": "^1.5.6",
    "@types/speakeasy": "^2.0.10",
    "@types/supertest": "^6.0.3",
    "husky": "^9.1.7",
    "prisma": "^7.6.0",
    "sharp": "^0.34.5",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  },
  "trustedDependencies": [
    "@swc/core"
  ]
}
