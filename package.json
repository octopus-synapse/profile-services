  "scripts": {
    "build": "nest build",
    "format": "biome format --write .",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "biome check --write .",
    "lint:fast": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "bun test src",
    "test:unit": "bun test src",
    "test:watch": "bun test src --watch",
    "test:coverage": "bun test src --coverage",
    "test:debug": "bun test src",
    "test:e2e": "./scripts/run-e2e.sh",
    "test:e2e:dev": "./scripts/run-e2e.sh dev",
    "test:e2e:prod": "./scripts/run-e2e.sh prod",
    "test:e2e:run": "DATABASE_URL=postgresql://postgres:postgres@localhost:5433/profile_test REDIS_HOST=localhost REDIS_PORT=6380 JWT_SECRET=e2e_test_secret_key_minimum_32_characters_long NODE_ENV=test bun test --config=bunfig.e2e.toml",
    "test:smoke": "bun test ./test/smoke",
    "test:integration": "./scripts/run-integration.sh",
    "test:integration:dev": "./scripts/run-integration.sh dev",
    "test:integration:test": "./scripts/run-integration.sh test",
    "test:integration:run": "DATABASE_URL=postgresql://postgres:postgres@localhost:5433/profile_test REDIS_HOST=localhost REDIS_PORT=6380 JWT_SECRET=test_secret_key_minimum_32_characters_long NODE_ENV=test bun test --config=bunfig.integration.toml",
    "db:setup:test": "bunx prisma generate --config ./prisma.config.ts && bunx prisma migrate deploy --config ./prisma.config.ts && bun run prisma/seed.ts",
    "test:static": "bun test --config=bunfig.static-analysis.toml",
    "test:arch": "bun test ./test/static-analysis/architecture",
    "test:contracts": "bun test ./test/static-analysis/contracts",
    "test:security": "bun test --config=bunfig.security.toml",
    "test:critical": "bun test --test-name-pattern critical",
    "test:fast": "bun test --bail",
    "test:changed": "bun test",
    "test:metrics": "bun test",
    "test:watch:verbose": "bun test --watch",
    "precommit": "./.husky/pre-commit",
    "ci:lint": "bun run lint",
    "ci:test": "bun run test:integration:run",
    "prisma:generate": "bunx prisma generate --config ./prisma.config.ts",
    "prisma:migrate": "bunx prisma migrate dev --config ./prisma.config.ts",
    "prisma:migrate:deploy": "bunx prisma migrate deploy --config ./prisma.config.ts",
    "prisma:push": "bunx prisma db push --config ./prisma.config.ts",
    "prisma:studio": "bunx prisma studio --config ./prisma.config.ts",
    "prisma:seed": "bun run prisma/seed.ts",
    "db:setup": "bunx prisma generate --config ./prisma.config.ts && bunx prisma migrate deploy --config ./prisma.config.ts",
    "db:reset": "bunx prisma migrate reset --config ./prisma.config.ts --force",
    "schemas:export": "bun run src/scripts/export-schemas.ts",
    "openapi:generate": "bun run src/scripts/generate-openapi.ts",
    "swagger:generate": "bun run scripts/generate-swagger-from-decorators.ts",
    "swagger:test": "bun test ./test/static-analysis/contracts/swagger-generation.contract.ts",
    "prepare": "husky"
  },
