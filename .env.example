# =============================================================================
# profile-services — environment template
#
# Source of truth for which env vars exist is `EnvConfigSchema` in
# src/shared-kernel/config/config.schema.ts. The boot-time validator
# rejects any deploy missing a required key. This file mirrors the
# schema 1:1 — the env-example.sync test fails CI if they diverge.
#
# Active line  -> `KEY=value`      operator-friendly default
# Comment line -> `# KEY=value`    optional; runtime defaults if unset
# =============================================================================


# --- Application ---
NODE_ENV=development
PORT=3001


# --- Database (PostgreSQL via Prisma) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=profile_dev
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/profile_dev?schema=public


# --- Redis (cache + BullMQ) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis
# Toggle the BullMQ queues. Off in unit tests; on in dev/staging/prod.
# ENABLE_BULLMQ=true


# --- JWT (REQUIRED — boot fails without JWT_SECRET >= 32 chars) ---
JWT_SECRET=your-development-secret-key-change-in-production-min-32-chars
# Optional zero-downtime rotation slot. Verifier tries JWT_SECRET first
# and falls back here on signature mismatch. Drop once the rotation
# window (= longest token lifetime) has elapsed.
# JWT_SECRET_PREVIOUS=
JWT_EXPIRATION=7d
# Required in production (boot fails otherwise — pins issuer/audience
# so tokens from one deploy can't be replayed against another).
# JWT_ISSUER=patch-careers
# JWT_AUDIENCE=patch-clients
# AUTH_COOKIE_NAME=patch_session
# Session cookie lifetimes (days). SESSION_EXPIRY_DAYS sizes a normal
# (non-"keep me signed in") browser session; PERSISTENT_SESSION_EXPIRY_DAYS
# sizes the persistent cookie when the user checks "keep me signed in" —
# it slides (renews) on each POST /v1/auth/refresh. Both optional.
# SESSION_EXPIRY_DAYS=7
# PERSISTENT_SESSION_EXPIRY_DAYS=30


# --- Symmetric encryption for stored OAuth tokens (P0-007) ---
# 32 raw bytes encoded as base64 (44 chars). Optional in dev (degrades
# to passthrough); REQUIRED in production by composition-root check.
# TOKEN_ENCRYPTION_KEY=


# --- LGPD / Consent versioning ---
# Bump these when the user-facing legal copy changes — forces a new
# accept flow. Mirror PUBLIC_TOS_VERSION on the frontend.
TOS_VERSION=1.0.0
PRIVACY_POLICY_VERSION=1.0.0
# MARKETING_CONSENT_VERSION=1.0.0
# SKIP_TOS_CHECK=false


# --- Email (SMTP via Mailpit in dev; SendGrid in prod) ---
EMAIL_FROM=noreply@profile.com
EMAIL_FROM_NAME=ProFile
SMTP_HOST=localhost
SMTP_PORT=1025
# SMTP_USER=
# SMTP_PASS=
# SMTP_SECURE=false
# Set in production only — overrides SMTP_*.
# SENDGRID_API_KEY=
# SENDGRID_EMAIL_FROM=
# SKIP_EMAIL_VERIFICATION=false


# --- Storage (MinIO / S3) ---
# Defaults match docker-compose.dev.yml. MINIO_PUBLIC_ENDPOINT is for
# when the backend talks to MinIO inside the Docker network but the
# user downloads via a public CDN URL.
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=profile-uploads
# MINIO_PUBLIC_ENDPOINT=https://cdn.patchcareers.com


# --- Application URLs (CORS, email links, frontend redirects) ---
BACKEND_URL=http://localhost:13001
FRONTEND_URL=http://localhost:3000
# PUBLIC_APP_URL=
# API_BASE_URL=
# UI_BASE_URL=
# Legacy — outbound email link bases now built from FRONTEND_URL.
# APP_URL=
# APP_VERSION=


# --- CORS / WebSocket origin allowlist ---
# Production: the web app (https://patchcareers.org) must be allowed WITH
# credentials so the httpOnly session cookie flows on cross-origin XHR to
# this API (https://backend.patchcareers.org). Same registrable domain →
# SameSite=Lax suffices; the cookie stays host-only on the API (no
# COOKIE_DOMAIN needed). credentials:true is already set in security-headers.
# CORS_ORIGIN=https://patchcareers.org
# CORS_ORIGIN=http://localhost:3000
# CORS_ALLOWED_ORIGINS extends CORS_ORIGIN — the buildCorsAllowlist
# helper merges both. Useful when the legacy single-source config
# needs to fan out to multiple origins.
# CORS_ALLOWED_ORIGINS=
# Empty set fails-closed (every WS upgrade rejected with 403).
# ALLOWED_WS_ORIGINS=http://localhost:3000


# --- Logging ---
LOG_LEVEL=debug


# --- Rate limit ---
# In NODE_ENV=test the guard auto-disables; flip true to force-run.
RATE_LIMIT_ENABLED=false
# RATE_LIMIT_MAX=100
# RATE_LIMIT_AUTH_MAX=10


# --- Login lock ---
# LOGIN_MAX_FAILED_ATTEMPTS=5
# LOGIN_LOCK_DURATION_MINUTES=15


# --- Bcrypt ---
# Boot rejects values < 10 (GPU brute-force range). Default 12.
# BCRYPT_COST=12


# --- Privacy: deterministic IP hashing (Wave 1.4) ---
# >= 32 chars random. Optional in dev (per-process random salt);
# REQUIRED in production via superRefine.
# IP_HASH_SALT=replace-with-32-or-more-random-bytes-base64


# --- Swagger / OpenAPI docs ---
# Keep false in production (exposes API surface + relaxes CSP).
ENABLE_SWAGGER=false


# --- OAuth providers ---
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_SECRET=
# GITHUB_OAUTH_CLIENT_ID=
# GITHUB_OAUTH_SECRET=
# LINKEDIN_OAUTH_CLIENT_ID=
# LINKEDIN_OAUTH_SECRET=
# Allowed OAuth return URIs (CSV). MUST include the web callback so the
# callback can 302 back with the session cookie, plus the native deep link.
# Empty = redirect_uri OAuth is rejected (fail-closed). Dev web origin is
# http://localhost:8081. Prod example:
#   https://patchcareers.org/oauth-callback,patchcareers://auth/callback
# OAUTH_REDIRECT_URI_ALLOWLIST=http://localhost:8081/oauth-callback,patchcareers://auth/callback
# Used for GitHub Linguist sync (cron.tech-skills) — read-only public.
# GITHUB_TOKEN=


# --- OpenAI / AI ---
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_MAX_TOKENS=2048
# OPENAI_SCORING_MODEL=gpt-4o-mini
# OPENAI_SCORING_MAX_TOKENS=2048
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Translation reuses OPENAI_MODEL but needs more headroom for resume single-call.
# OPENAI_TRANSLATION_MAX_TOKENS=4000


# --- Analytics (PostHog self-hosted) ---
# POSTHOG_HOST=http://posthog:8000
# POSTHOG_API_KEY=


# --- Typst PDF rendering / Puppeteer ---
# TYPST_BINARY_PATH=typst
# TYPST_FONT_PATH=/usr/share/fonts/resume-fonts
# TYPST_TEMPLATES_PATH=
# PUPPETEER_HOST=
# PUPPETEER_PORT=


# --- Internal / CI ---
# Used for cross-service calls from GitHub Actions cron workflows
# (cron.mec-sync, cron.tech-skills). Generate a long random token.
INTERNAL_API_TOKEN=generate-a-secure-random-token-here
# PROMETHEUS_KEY=
# SDK_COVERAGE_MODE=


# --- Safe-fetch / SSRF defense (P1 #45/#46, Wave 1.5) ---
# Hard cap on response body SafeFetchStrictAdapter will read from a
# webhook target before aborting with BodyTooLargeException.
# Default 5_000_000 (5 MB).
SAFE_FETCH_MAX_BYTES=5000000


# --- Attestation witness (P2-129) ---
# PEM-encoded RSA/ED25519 private key. Keep the literal \n sequences;
# the env loader unescapes them at boot. Quote the whole value so the
# shell doesn't split on embedded newlines.
ATTESTATION_WITNESS_STORAGE_PATH=/app/attestation-witness
ATTESTATION_WITNESS_SIGNING_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nreplace-me\n-----END PRIVATE KEY-----"
ATTESTATION_WITNESS_KEY_ID=witness-key-2026-03-25
ATTESTATION_WITNESS_CHECK_SCRIPT=/app/scripts/run-attestation-witness-checks.sh
