# ==================================
# Application Configuration
# ==================================
NODE_ENV=development
PORT=3001

# ==================================
# Database Configuration (PostgreSQL)
# ==================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=profile_dev
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/profile_dev?schema=public

# ==================================
# Redis Configuration
# ==================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis

# ==================================
# JWT Configuration
# ==================================
JWT_SECRET=your-development-secret-key-change-in-production
JWT_EXPIRATION=7d

# ==================================
# GDPR Compliance - Consent Versioning
# ==================================
TOS_VERSION=1.0.0
PRIVACY_POLICY_VERSION=1.0.0

# ==================================
# Email Configuration
# ==================================
EMAIL_FROM=noreply@profile.com
EMAIL_FROM_NAME=ProFile

# SMTP (Mailpit in dev - UI at http://localhost:8025)
SMTP_HOST=localhost
SMTP_PORT=1025

# SendGrid (production only)
# SENDGRID_API_KEY=
# SENDGRID_EMAIL_FROM=

# ==================================
# MinIO S3-compatible Storage Configuration
# Defaults match docker-compose.dev.yml's bundled MinIO container.
# ==================================
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=profile-uploads

# ==================================
# Application URLs
# ==================================
BACKEND_URL=http://localhost:13001

# ==================================
# Typst PDF Rendering (optional overrides)
# ==================================
# TYPST_BINARY_PATH=typst
# TYPST_FONT_PATH=/usr/share/fonts/resume-fonts
# TYPST_TEMPLATES_PATH=

# ==================================
# Frontend integration
# ==================================
# URL público do frontend — usado em CORS, emails transacionais, chat gateway
FRONTEND_URL=http://localhost:3000

# ==================================
# Swagger / OpenAPI docs
# ==================================
# Ativa Swagger UI. Manter false em produção (expõe surface da API + CSP mais fraca).
ENABLE_SWAGGER=false

# ==================================
# Rate limiting
# ==================================
# Em testes (NODE_ENV=test) rate-limit fica desativado por default;
# setar 'true' força o guard rodar mesmo em teste.
RATE_LIMIT_ENABLED=false

# ==================================
# MinIO / S3 public-facing endpoint
# ==================================
# Usado quando o endpoint interno (MINIO_ENDPOINT) difere da URL pública
# (ex.: backend fala com MinIO na rede Docker, mas usuário baixa pela internet).
# MINIO_PUBLIC_ENDPOINT=https://cdn.patchcareers.com

# ==================================
# Themes — preview
# ==================================
# ID do resume usado como sample em previews de temas no admin
# THEME_PREVIEW_RESUME_ID=

# ==================================
# PostHog (analytics self-hosted — Dia 1 tarefa 4)
# ==================================
# POSTHOG_HOST=http://posthog:8000
# POSTHOG_API_KEY=

# ==================================
# LGPD — versões de consentimento
# ==================================
# Mantém sincronizado com PUBLIC_TOS_VERSION / PUBLIC_PRIVACY_POLICY_VERSION do frontend.
# Bump sempre que o texto das páginas legais mudar (força novo aceite).
# TOS_VERSION e PRIVACY_POLICY_VERSION já existem acima.

# ==================================
# Logging
# ==================================
LOG_LEVEL=debug

# ==================================
# Internal API Configuration
# Used for GitHub Actions and internal services
# ==================================
INTERNAL_API_TOKEN=generate-a-secure-random-token-here

# ==================================
# Attestation Witness Configuration
# ==================================
ATTESTATION_WITNESS_STORAGE_PATH=/app/attestation-witness
# P2-129 — the private key is a PEM-encoded RSA/ED25519 key. Keep the
# literal `\n` sequences (do NOT replace with real newlines): the env
# loader unescapes them at boot. Quote the entire value so shells
# don't split on the embedded `\n`.
ATTESTATION_WITNESS_SIGNING_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nreplace-me\n-----END PRIVATE KEY-----"
ATTESTATION_WITNESS_KEY_ID=witness-key-2026-03-25
ATTESTATION_WITNESS_CHECK_SCRIPT=/app/scripts/run-attestation-witness-checks.sh
