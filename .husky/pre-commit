#!/bin/sh
# =============================================================================
# Pre-Commit Hook - Fast Feedback Loop + Attestation with Metrics
# =============================================================================
#
# What runs here (in parallel where possible):
#   0. Swagger generation (MUST be first - generates files)
#   1-5. In parallel: TypeCheck, Lint, Unit Tests, Arch Tests, Contract Tests
#   6. Generate attestation with metrics (tree hash proof + check results)
#
# Security:
#   The attestation includes the git tree hash of all staged files.
#   CI verifies this hash matches the committed code.
#   Any modification after checks = hash mismatch = CI rejects.
#
# =============================================================================

set -e

# Create temp dir for parallel output
TMPDIR=$(mktemp -d)
trap "rm -rf $TMPDIR" EXIT

# Helper: run check with timing
run_timed() {
    local name="$1"
    local cmd="$2"
    local start end elapsed
    start=$(date +%s%3N 2>/dev/null || date +%s)
    if eval "$cmd" > "$TMPDIR/${name}.log" 2>&1; then
        echo "OK" > "$TMPDIR/${name}.status"
    else
        echo "FAIL" > "$TMPDIR/${name}.status"
    fi
    end=$(date +%s%3N 2>/dev/null || date +%s)
    echo "$((end - start))" > "$TMPDIR/${name}.time"
}

# Helper: extract test metrics from bun test output
extract_test_metrics() {
    local logfile="$1"
    local passed=0 failed=0 skipped=0
    # bun test output: "X pass, Y fail, Z skip"
    if grep -qE "[0-9]+ pass" "$logfile" 2>/dev/null; then
        passed=$(grep -oE "[0-9]+ pass" "$logfile" | head -1 | grep -oE "[0-9]+" || echo 0)
        failed=$(grep -oE "[0-9]+ fail" "$logfile" | head -1 | grep -oE "[0-9]+" || echo 0)
        skipped=$(grep -oE "[0-9]+ skip" "$logfile" | head -1 | grep -oE "[0-9]+" || echo 0)
    fi
    echo "${passed}:${failed}:${skipped}"
}

echo "Pre-commit checks..."
echo ""

# -----------------------------------------------------------------------------
# 0. Generate Swagger from @SdkExport decorators (MUST be first)
# -----------------------------------------------------------------------------
echo "  [0/6] Generating swagger.json..."
SWAGGER_START=$(date +%s%3N 2>/dev/null || date +%s)
if bun run scripts/generate-swagger-from-decorators.ts > "$TMPDIR/swagger.log" 2>&1; then
    bunx biome format --write src/graphql/schema.graphql 2>/dev/null || true
    git add swagger.json swagger-generation-report.json
    git add src/graphql/schema.graphql 2>/dev/null || true
    git add generated/schema.graphql 2>/dev/null || true
    SWAGGER_END=$(date +%s%3N 2>/dev/null || date +%s)
    echo "$((SWAGGER_END - SWAGGER_START))" > "$TMPDIR/swagger.time"
    echo "OK" > "$TMPDIR/swagger.status"
else
    echo "  ❌ Swagger generation failed"
    cat "$TMPDIR/swagger.log"
    exit 1
fi

# -----------------------------------------------------------------------------
# 1-5. Run checks in PARALLEL with timing
# -----------------------------------------------------------------------------
echo "  [1-5] Running checks in parallel..."

# TypeCheck
(run_timed "typecheck" "bun run typecheck") &
PID_TC=$!

# Lint
(run_timed "lint" "bun run lint:fast") &
PID_LINT=$!

# Unit Tests
(run_timed "unit" "bun test src/") &
PID_UNIT=$!

# Architecture Tests
(run_timed "arch" "bun test ./test/static-analysis/architecture") &
PID_ARCH=$!

# Contract Tests
(run_timed "contract" "bun test ./test/static-analysis/contracts") &
PID_CONTRACT=$!

# Wait for all processes
wait $PID_TC $PID_LINT $PID_UNIT $PID_ARCH $PID_CONTRACT

# Check results and report
FAILED=0

check_result() {
    local name="$1"
    local display="$2"
    local time_ms=$(cat "$TMPDIR/${name}.time" 2>/dev/null || echo "0")
    local time_s=$(awk "BEGIN {printf \"%.1f\", $time_ms/1000}")

    if [ "$(cat $TMPDIR/${name}.status)" = "FAIL" ]; then
        echo "  ❌ $display failed (${time_s}s)"
        cat "$TMPDIR/${name}.log"
        FAILED=1
    else
        echo "  ✓ $display (${time_s}s)"
    fi
}

check_result "typecheck" "TypeCheck"
check_result "lint" "Lint"
check_result "unit" "Unit tests"
check_result "arch" "Architecture tests"
check_result "contract" "Contract tests"

if [ $FAILED -eq 1 ]; then
    echo ""
    echo "Pre-commit failed!"
    exit 1
fi

# -----------------------------------------------------------------------------
# 6. Generate Attestation with Metrics
# -----------------------------------------------------------------------------
echo "  [6/6] Generating attestation..."

# Extract metrics
UNIT_METRICS=$(extract_test_metrics "$TMPDIR/unit.log")
ARCH_METRICS=$(extract_test_metrics "$TMPDIR/arch.log")
CONTRACT_METRICS=$(extract_test_metrics "$TMPDIR/contract.log")

# Build metrics JSON
METRICS_JSON=$(cat <<EOF
{
  "swagger": {"status":"ok","time_ms":$(cat "$TMPDIR/swagger.time")},
  "typecheck": {"status":"ok","time_ms":$(cat "$TMPDIR/typecheck.time")},
  "lint": {"status":"ok","time_ms":$(cat "$TMPDIR/lint.time")},
  "unit": {"status":"ok","time_ms":$(cat "$TMPDIR/unit.time"),"passed":$(echo "$UNIT_METRICS" | cut -d: -f1),"failed":$(echo "$UNIT_METRICS" | cut -d: -f2),"skipped":$(echo "$UNIT_METRICS" | cut -d: -f3)},
  "arch": {"status":"ok","time_ms":$(cat "$TMPDIR/arch.time"),"passed":$(echo "$ARCH_METRICS" | cut -d: -f1),"failed":$(echo "$ARCH_METRICS" | cut -d: -f2),"skipped":$(echo "$ARCH_METRICS" | cut -d: -f3)},
  "contracts": {"status":"ok","time_ms":$(cat "$TMPDIR/contract.time"),"passed":$(echo "$CONTRACT_METRICS" | cut -d: -f1),"failed":$(echo "$CONTRACT_METRICS" | cut -d: -f2),"skipped":$(echo "$CONTRACT_METRICS" | cut -d: -f3)}
}
EOF
)

export ATTESTATION_CHECKS="typecheck,lint,test,arch,contracts"
export ATTESTATION_METRICS="$METRICS_JSON"
./scripts/attestation.sh generate

echo ""
echo "Pre-commit passed!"
