#!/bin/sh
# =============================================================================
# Pre-Commit Hook - Fast Feedback Loop + Simple Attestation
# =============================================================================
#
# What runs here:
#   1. Swagger generation (decorators → openapi spec)
#   2. Type checking (TypeScript)
#   3. Linting (Biome)
#   4. Unit tests (mocked, in-memory)
#   5. Architecture tests (import boundaries)
#   6. Contract tests (API contracts)
#   7. Generate attestation (tree hash proof)
#
# Security:
#   The attestation includes the git tree hash of all staged files.
#   CI verifies this hash matches the committed code.
#   Any modification after checks = hash mismatch = CI rejects.
#
# =============================================================================

set -e

echo "Pre-commit checks..."
echo ""

# -----------------------------------------------------------------------------
# 0. Generate Swagger from @SdkExport decorators (MUST be first)
# -----------------------------------------------------------------------------
echo "  Generating swagger.json..."
if bun run scripts/generate-swagger-from-decorators.ts; then
    bunx biome format --write src/graphql/schema.graphql 2>/dev/null || true
    git add swagger.json swagger-generation-report.json
    git add src/graphql/schema.graphql 2>/dev/null || true
    git add generated/schema.graphql 2>/dev/null || true
else
    echo "Swagger generation failed"
    exit 1
fi

# -----------------------------------------------------------------------------
# 1. Type Check
# -----------------------------------------------------------------------------
echo "  Type checking..."
if ! bun run typecheck; then
    echo "Type check failed"
    exit 1
fi

# -----------------------------------------------------------------------------
# 2. Lint
# -----------------------------------------------------------------------------
echo "  Linting..."
if ! bun run lint:fast; then
    echo "Lint failed"
    exit 1
fi

# -----------------------------------------------------------------------------
# 3. Unit Tests
# -----------------------------------------------------------------------------
echo "  Running unit tests..."
if ! bun test src/; then
    echo "Unit tests failed"
    exit 1
fi

# -----------------------------------------------------------------------------
# 4. Architecture Tests
# -----------------------------------------------------------------------------
echo "  Running architecture tests..."
if ! bun test ./test/architecture; then
    echo "Architecture tests failed"
    exit 1
fi

# -----------------------------------------------------------------------------
# 5. Contract Tests
# -----------------------------------------------------------------------------
echo "  Running contract tests..."
if ! bun test ./test/contracts; then
    echo "Contract tests failed"
    exit 1
fi

# -----------------------------------------------------------------------------
# 6. Generate Attestation (tree hash proof)
# -----------------------------------------------------------------------------
echo "  Generating attestation..."
ATTESTATION_CHECKS="typecheck,lint,test,arch,contracts" ./scripts/attestation.sh generate

echo ""
echo "Pre-commit passed!"
