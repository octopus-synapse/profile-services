// Feed: Posts, Comments, Likes, Bookmarks, Reports, Polls

model Post {
  id       String @id @default(dbgenerated("uuidv7()"))
  authorId String
  author   User   @relation("UserPosts", fields: [authorId], references: [id])

  type    PostType
  subtype String?

  // Global content
  content    String?  @db.Text
  hardSkills String[]
  softSkills String[]
  hashtags   String[]

  // Structured data per post type (flexible JSON)
  data Json?

  // Media
  imageUrl    String?
  linkUrl     String?
  linkPreview Json? // { title, description, image, domain }

  // Repost
  originalPostId String?
  originalPost   Post?   @relation("Reposts", fields: [originalPostId], references: [id])
  reposts        Post[]  @relation("Reposts")

  // Co-authors
  coAuthors String[]

  // Scheduling
  scheduledAt DateTime?
  isPublished Boolean   @default(true)

  // Thread
  threadId String?

  // Poll
  pollDeadline DateTime?
  votesCount   Int       @default(0)

  // Code snippet
  codeSnippet Json?

  // Denormalized counters
  likesCount     Int @default(0)
  commentsCount  Int @default(0)
  repostsCount   Int @default(0)
  bookmarksCount Int @default(0)

  // Status
  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  // Blind Mode — when `isAnonymous=true` the feed serializer hides author
  // identity (id, name, photo, username) and shows a generic label derived
  // from the author's headline/role. The row still references `authorId`
  // internally so moderation, spam control, and per-user rate limits keep
  // working; `anonymousCategory` narrows the toggle to legitimate topics.
  isAnonymous       Boolean            @default(false)
  anonymousCategory AnonymousCategory?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  likes     PostLike[]
  comments  PostComment[]
  bookmarks PostBookmark[]
  reports   PostReport[]
  pollVotes PollVote[]

  @@index([authorId, createdAt])
  @@index([type, createdAt])
  @@index([createdAt])
  @@index([originalPostId])
  @@index([originalPostId, authorId])
  @@index([threadId])
}

model PostComment {
  id       String @id @default(dbgenerated("uuidv7()"))
  postId   String
  post     Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId String
  author   User   @relation("UserComments", fields: [authorId], references: [id])

  content  String        @db.Text
  parentId String?
  parent   PostComment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies  PostComment[] @relation("CommentReplies")

  isDeleted Boolean   @default(false)
  // P1-067 — `deletedAt` complements the boolean so the audit trail
  // records WHEN the comment was soft-deleted, not just THAT it
  // was. Old rows stay null (no information loss); new soft-deletes
  // populate it via the `MarkPostCommentDeletedUseCase`.
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([postId, createdAt])
  @@index([parentId])
}

model PostLike {
  id     String @id @default(dbgenerated("uuidv7()"))
  postId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId String
  user   User   @relation("UserLikes", fields: [userId], references: [id])

  reactionType ReactionType @default(LIKE)

  createdAt DateTime @default(now())

  @@unique([postId, userId])
  // P1-024 — `listReactionsByUser(userId, page, limit)` orders by
  // createdAt DESC. Without this index Postgres scans every row whose
  // userId matches then sorts in memory; with it the planner walks the
  // index in reverse and stops at `limit`.
  @@index([userId, createdAt])
}

model PostBookmark {
  id     String @id @default(dbgenerated("uuidv7()"))
  postId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId String
  user   User   @relation("UserBookmarks", fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@unique([postId, userId])
  // P1-025 — same access pattern as `PostLike`: every "my bookmarks"
  // query orders by createdAt and only fetches the first page.
  @@index([userId, createdAt])
}

model PostReport {
  id     String @id @default(dbgenerated("uuidv7()"))
  postId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId String
  user   User   @relation("UserReports", fields: [userId], references: [id])

  reason String       @db.Text
  status ReportStatus @default(PENDING)

  createdAt DateTime @default(now())

  @@unique([postId, userId])
}

model PollVote {
  id          String @id @default(dbgenerated("uuidv7()"))
  postId      String
  post        Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId      String
  optionIndex Int

  createdAt DateTime @default(now())

  @@unique([postId, userId])
}
