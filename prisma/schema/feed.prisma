// Feed: Posts, Comments, Likes, Bookmarks, Reports, Polls

model Post {
  id       String @id @default(dbgenerated("uuidv7()"))
  authorId String
  author   User   @relation("UserPosts", fields: [authorId], references: [id])

  // Global content
  content  String?  @db.Text
  hashtags String[]

  // Media
  imageUrl    String?
  videoUrl    String?
  linkUrl     String?
  linkPreview Json? // { title, description, image, domain }

  // Repost — quote-repost when content is set; pure repost otherwise.
  isRepost       Boolean @default(false)
  originalPostId String?
  originalPost   Post?   @relation("Reposts", fields: [originalPostId], references: [id])
  reposts        Post[]  @relation("Reposts")

  // Scheduling
  scheduledAt DateTime?
  isPublished Boolean   @default(true)

  // Thread
  threadId String?

  // Poll — single-vote, optional deadline. `pollOptions` is a JSON array of
  // { label: string } objects; tallies are derived from PollVote.
  pollOptions  Json?
  pollDeadline DateTime?
  votesCount   Int       @default(0)

  // Code snippet — promoted to first-class columns (replaces legacy `data` JSON).
  codeSnippet  String? @db.Text
  codeLanguage String? @db.VarChar(40)

  // Denormalized counters
  likesCount     Int @default(0)
  commentsCount  Int @default(0)
  repostsCount   Int @default(0)
  bookmarksCount Int @default(0)

  // Status
  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  likes     PostLike[]
  comments  PostComment[]
  bookmarks PostBookmark[]
  reports   PostReport[]
  pollVotes PollVote[]

  @@index([authorId, createdAt])
  @@index([createdAt])
  @@index([originalPostId])
  @@index([originalPostId, authorId])
  @@index([threadId])
}

model PostComment {
  id       String @id @default(dbgenerated("uuidv7()"))
  postId   String
  post     Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId String
  author   User   @relation("UserComments", fields: [authorId], references: [id])

  content  String        @db.Text
  parentId String?
  parent   PostComment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies  PostComment[] @relation("CommentReplies")

  isDeleted Boolean   @default(false)
  // P1-067 — `deletedAt` complements the boolean so the audit trail
  // records WHEN the comment was soft-deleted, not just THAT it
  // was. Old rows stay null (no information loss); new soft-deletes
  // populate it via the `MarkPostCommentDeletedUseCase`.
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([postId, createdAt])
  @@index([parentId])
}

model PostLike {
  id     String @id @default(dbgenerated("uuidv7()"))
  postId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId String
  user   User   @relation("UserLikes", fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@unique([postId, userId])
  // P1-024 — `listLikesByUser(userId, page, limit)` orders by
  // createdAt DESC. Without this index Postgres scans every row whose
  // userId matches then sorts in memory; with it the planner walks the
  // index in reverse and stops at `limit`.
  @@index([userId, createdAt])
}

model PostBookmark {
  id     String @id @default(dbgenerated("uuidv7()"))
  postId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId String
  user   User   @relation("UserBookmarks", fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@unique([postId, userId])
  // P1-025 — same access pattern as `PostLike`: every "my bookmarks"
  // query orders by createdAt and only fetches the first page.
  @@index([userId, createdAt])
}

model PostReport {
  id     String @id @default(dbgenerated("uuidv7()"))
  postId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId String
  user   User   @relation("UserReports", fields: [userId], references: [id])

  reason String       @db.Text
  status ReportStatus @default(PENDING)

  createdAt DateTime @default(now())

  @@unique([postId, userId])
}

model PollVote {
  id          String @id @default(dbgenerated("uuidv7()"))
  postId      String
  post        Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId      String
  optionIndex Int

  createdAt DateTime @default(now())

  @@unique([postId, userId])
}
