// Resume Sections - Generic section model (single canonical source)

model SectionType {
  id           String  @id @default(cuid())
  key          String  @unique
  slug         String
  title        String
  description  String?
  semanticKind String
  version      Int     @default(1)

  isActive     Boolean @default(true)
  isSystem     Boolean @default(true)
  isRepeatable Boolean @default(true)
  minItems     Int     @default(0)
  maxItems     Int?

  definition Json
  uiSchema   Json?

  // Style DSL - Backend-driven rendering configuration
  // renderHints: { layout: "timeline"|"list"|"grid"|"cards", groupBy?: string, dateFormat?: string }
  renderHints Json @default("{}")
  // fieldStyles: { [fieldKey]: { semantic: "title"|"subtitle"|"date"|"link", widget?: string, width?: string } }
  fieldStyles Json @default("{}")

  // Icon system: "emoji" (💼) or "lucide" (briefcase)
  iconType String @default("emoji")
  icon     String @default("📄")

  // i18n: Translations stored as JSON per locale
  // Format: { "en": { "title": "...", "label": "...", ... }, "pt-BR": { ... }, "es": { ... } }
  translations Json @default("{}")

  // Field examples for onboarding placeholders
  // Format: { "company": ["Google", "Nubank", "iFood"], "role": ["Senior Developer", "Tech Lead"] }
  examples Json @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  resumeSections    ResumeSection[]
  onboardingSteps   OnboardingStep[]

  @@unique([slug, version])
  @@index([semanticKind])
  @@index([isActive])
}

model ResumeSection {
  id       String @id @default(cuid())
  resumeId String
  resume   Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  sectionTypeId String
  sectionType   SectionType @relation(fields: [sectionTypeId], references: [id], onDelete: Restrict)

  titleOverride String?
  isVisible     Boolean @default(true)
  order         Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items SectionItem[]

  @@unique([resumeId, sectionTypeId])
  @@index([resumeId, order])
  @@index([sectionTypeId])
}

model SectionItem {
  id              String @id @default(cuid())
  resumeSectionId String
  resumeSection   ResumeSection @relation(fields: [resumeSectionId], references: [id], onDelete: Cascade)

  content Json

  isVisible Boolean @default(true)
  order     Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([resumeSectionId, order])
  @@index([resumeSectionId])
}
