// Resume Analytics - View-tracking sibling projection. The scoring columns
// (atsScore, keywordScore, completenessScore, industryRank, totalInIndustry,
// topKeywords, missingKeywords, improvementSuggestions) were removed in the
// scoring refactor — they now live in `ResumeQualityScoreHistory`
// (see `resume-quality/` bounded context).

model ResumeAnalytics {
  id       String @id @default(dbgenerated("uuidv7()"))
  resumeId String
  resume   Resume @relation("ResumeAnalytics", fields: [resumeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([resumeId])
  @@index([createdAt])
  @@map("resume_analytics")
}

model ResumeViewEvent {
  id       String @id @default(dbgenerated("uuidv7()"))
  resumeId String
  resume   Resume @relation("ResumeViews", fields: [resumeId], references: [id], onDelete: Cascade)

  // Anonymized tracking (GDPR)
  ipHash    String // SHA-256 hashed IP
  userAgent String?
  referer   String?

  // Geo data
  country String? // ISO 3166-1 alpha-2
  city    String?

  // Traffic source
  source String @default("direct") // linkedin, github, google, direct, etc.

  createdAt DateTime @default(now())

  @@index([resumeId])
  @@index([createdAt])
  @@index([source])
  @@index([resumeId, createdAt])
  @@map("resume_view_events")
}
