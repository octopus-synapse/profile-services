// Resume Style System - ATS-safe visual styles for resumes (formerly ResumeTheme).
//
// Every ResumeStyle is ATS-safe by invariant: creation/update below the
// configured Style Score threshold is rejected (422). The score is computed
// from the design config by the data-driven rubric (StyleScoringCriterion)
// and is free to move in either direction as a template is edited.

model ResumeStyle {
  id String @id @default(dbgenerated("uuidv7()"))

  name        String
  description String? @db.Text

  authorId String
  author   User   @relation("StyleAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  // Versioning (numeric, incremented on each admin edit)
  version     Int  @default(1)
  historyJson Json @default("[]") // [{ version, styleScore, changedAt, changedBy }]

  // Style Score (0-100) + breakdown computed by the data-driven rubric.
  styleScore          Int  @default(0) // 0-100, recomputed from styleConfig
  styleScoreBreakdown Json @default("{}") // { buckets: { ...bucket: points }, issues: StyleIssue[] }

  // Layout & template
  layoutKind    LayoutKind @default(SINGLE_COLUMN)
  typstTemplate String // identifier/path in export/infrastructure/typst/templates/

  // Core style configuration (design tokens: palette, fonts, spacing, margens)
  styleConfig Json

  // Style DSL - Per-section style overrides
  // Format: { "work_experience_v1": { container: {...}, title: {...}, content: {...} } }
  sectionStyles Json @default("{}")

  thumbnailUrl  String?
  previewImages String[]

  isSystem Boolean @default(false)

  // Fork lineage
  parentStyleId String?
  parentStyle   ResumeStyle?  @relation("StyleForks", fields: [parentStyleId], references: [id], onDelete: SetNull)
  forks         ResumeStyle[] @relation("StyleForks")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  resumes            Resume[]             @relation("ResumeActiveStyle")
  onboardingProgress OnboardingProgress[] @relation("OnboardingProgressStyle")

  @@index([authorId])
  @@index([isSystem])
  @@index([createdAt])
}

// Data-driven Style Score rubric. Each row is one tunable criterion: the
// evaluator function is code (keyed by `key`), while weight / severity /
// thresholds / allowlists live here so the rubric can be tuned without a
// deploy. Mirrors the `SectionType.definition.ats.scoring` catalog pattern.
//
// `bucket` and `severity` are plain strings (not Prisma enums) on purpose —
// they're internal scoring metadata, not user-facing enums, so they stay out
// of the i18n ENUM_DICTIONARY parity surface.
model StyleScoringCriterion {
  id       String  @id @default(dbgenerated("uuidv7()"))
  key      String  @unique // stable id matched to a code evaluator, e.g. "structure.single_column_layout"
  bucket   String // score bucket: structure | typography | contrast | decorations
  weight   Int // points awarded when the criterion passes
  severity String // high | medium | low — severity of the emitted issue on failure
  params   Json    @default("{}") // allowlists / thresholds the evaluator reads
  active   Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active])
}
