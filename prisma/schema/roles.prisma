// Job-title dictionary powering the Add Experience role autocomplete.
// Populated from ESCO v1.2 (en+pt), CBO 2002 (pt) and O*NET (en) by
// `bun run roles:import` (src/scripts/import-roles.ts) and read by
// `PrismaRoleSearchAdapter`.
//
// `normalizedLabel` holds the diacritic-stripped, lower-cased label so search
// never calls `immutable_unaccent` per row at query time. The unique on
// (lang, normalizedLabel) plus the import order (esco → cbo → onet, with
// `skipDuplicates`) dedupes overlapping titles across sources, keeping the
// ESCO row (and its conceptUri) when sources collide. The trigram GIN index
// backing the contains tier is added via raw SQL in the migration.

enum RoleTitleSource {
  ESCO
  CBO
  ONET
  /// Hand-curated seniority variants generated from the role catalog
  /// (Estagiário/Júnior/Pleno/Sênior/Trainee · Intern/Junior/Senior…).
  CURATED
}

enum RoleTitleLang {
  EN
  PT
}

/// Seniority level a CURATED title encodes. Null for imported
/// occupational titles (ESCO/CBO/O*NET model the occupation, not the
/// vínculo). INTERN is the only level the employment-type invariant
/// pins to INTERNSHIP; TRAINEE is CLT and does NOT pin.
enum RoleSeniority {
  INTERN
  JUNIOR
  MID
  SENIOR
  TRAINEE
}

model RoleTitle {
  id              String          @id @default(dbgenerated("uuidv7()"))
  label           String
  normalizedLabel String
  lang            RoleTitleLang
  source          RoleTitleSource
  /// ESCO conceptUri | CBO code | O*NET SOC code — kept so EN↔PT title
  /// mapping can be built later without re-importing.
  sourceId        String?
  /// true = preferredLabel / título oficial; false = altLabel / sinônimo.
  isPreferred     Boolean         @default(false)
  /// CURATED only: the seniority level this title encodes (null for
  /// imported occupational titles).
  seniority       RoleSeniority?
  /// CURATED only: catalog key of the base occupation this variant was
  /// generated from — groups every PT/EN variant of one occupation and
  /// carries the EN↔PT mapping without a join table.
  baseRoleKey     String?

  @@unique([lang, normalizedLabel])
  @@index([lang])
  @@index([baseRoleKey])
}
