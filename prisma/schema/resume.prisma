// Resume Model - Core resume entity

model Resume {
  id     String @id @default(dbgenerated("uuidv7()"))
  userId String
  user   User   @relation("UserResumes", fields: [userId], references: [id], onDelete: Cascade)

  title    String?
  language String  @default("pt-br")
  isPublic Boolean @default(false)
  slug     String? @unique

  // Bilingual content
  contentPtBr     Json?
  contentEn       Json?
  primaryLanguage String @default("pt-br")

  // Tech Persona
  techPersona     String?
  techArea        String?
  primaryStack    String[]
  experienceYears Int?     @default(0)

  // Contact info — email is intentionally NOT stored here. The canonical
  // address lives on `User.email` and is read via the `user` relation.
  fullName String?
  jobTitle String?
  phone    String?
  location String?
  linkedin String?
  github   String?
  website  String?
  summary  String? @db.Text

  currentCompanyLogo String?

  // Social links
  twitter       String?
  medium        String?
  devto         String?
  stackoverflow String?
  kaggle        String?
  hackerrank    String?
  leetcode      String?

  // Visual customization
  accentColor String? @default("#3B82F6")
  customTheme Json?

  // Resume Style System — the single source of truth for visual style.
  // The legacy free-string `template` column (PROFESSIONAL/CREATIVE/...)
  // was removed: it had no writers, no readers, and only existed in the
  // Zod request schema. ResumeStyle covers ATS-safety + render pipeline
  // wiring via `typstTemplate`.
  styleId String?
  style   ResumeStyle? @relation("ResumeActiveStyle", fields: [styleId], references: [id], onDelete: SetNull)

  // Stats
  profileViews Int @default(0)
  totalStars   Int @default(0)
  totalCommits Int @default(0)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  publishedAt DateTime?

  // Relations
  users               User[]                      @relation("UserPrimaryResume")
  resumeSections      ResumeSection[]
  shares              ResumeShare[]               @relation("ResumeShares")
  versions            ResumeVersion[]             @relation("ResumeVersions")
  analytics           ResumeAnalytics[]           @relation("ResumeAnalytics")
  qualityScoreHistory ResumeQualityScoreHistory[]
  viewEvents          ResumeViewEvent[]           @relation("ResumeViews")
  import              ResumeImport?
  collaborators       ResumeCollaborator[]        @relation("ResumeCollaborators")
  collabComments      CollaborationComment[]      @relation("ResumeComments")

  @@index([userId])
  // P2-#34: `slug` is already `@unique` which implicitly creates an
  // index; the redundant `@@index([slug])` was a write-amplification cost
  // with no read benefit.
  @@index([isPublic])
  @@index([createdAt])
  @@index([techPersona])
  @@index([styleId])
  @@index([primaryLanguage])
}
