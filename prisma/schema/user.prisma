// User and Preferences Models

model User {
  id            String    @id @default(dbgenerated("uuidv7()"))
  name          String?
  email         String?   @unique
  /// Timestamp when the email was verified. `null` = unverified.
  /// (Historically named `emailVerified`; kept for code-base churn.)
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  isActive      Boolean   @default(true)
  lastLoginAt   DateTime?

  // Legacy roles column. The new authorization model uses
  // `UserRoleAssignment` rows; this array is kept as a denormalized
  // shadow for code paths still reading it during migration.
  roles String[] @default([])

  accounts Account[]
  sessions Session[]

  // Profile fields
  username          String?   @unique
  usernameUpdatedAt DateTime?
  photoURL          String?
  bio               String?   @db.Text
  /// One-line professional headline shown in feed cards, e.g. "Frontend Engineer @ Vercel".
  /// Distinct from `bio` (long paragraph). User-editable in /my-profile/edit + onboarding step.
  headline          String?   @db.VarChar(120)
  location          String?
  phone             String?
  website           String?
  linkedin          String?
  github            String?

  // Primary resume for settings/profile
  primaryResumeId String?
  primaryResume   Resume? @relation("UserPrimaryResume", fields: [primaryResumeId], references: [id], onDelete: SetNull)

  // Onboarding tracking — `onboardingCompletedAt != null` is the
  // single source of truth. The legacy denormalized boolean
  // (`hasCompletedOnboarding`) was dropped: code that exposes the
  // boolean to clients now derives it from this column.
  onboardingCompletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  resumes            Resume[]            @relation("UserResumes")
  preferences        UserPreferences?
  onboardingProgress OnboardingProgress?
  auditLogs          AuditLog[]
  consents           UserConsent[]       @relation("UserConsents")

  // Resume style system
  authoredStyles ResumeStyle[] @relation("StyleAuthor")

  // Scoring subsystem: fit profile + per-user answers/question sets
  fitProfile        UserFitProfile?
  fitAnswers        FitAnswer[]       @relation("UserFitAnswers")
  fitQuestionSets   FitQuestionSet[]  @relation("UserFitQuestionSets")
  fitRemapHistory   FitRemapHistory[] @relation("UserFitRemapHistory")

  // Chat system
  conversationsAsParticipant1 Conversation[]            @relation("ConversationParticipant1")
  conversationsAsParticipant2 Conversation[]            @relation("ConversationParticipant2")
  sentMessages                Message[]                 @relation("SentMessages")
  blockedUsers                BlockedUser[]             @relation("Blocker")
  blockedByUsers              BlockedUser[]             @relation("Blocked")
  conversationPreferences     ConversationPreference[]  @relation("UserConversationPrefs")

  // Social features
  followers  Follow[]   @relation("Following")
  following  Follow[]   @relation("Followers")
  activities Activity[] @relation("UserActivities")

  // Connection features
  sentConnections     Connection[] @relation("SentConnections")
  receivedConnections Connection[] @relation("ReceivedConnections")

  // Two-Factor Authentication
  twoFactorAuth        TwoFactorAuth?
  twoFactorBackupCodes TwoFactorBackupCode[]

  // Email logging
  emailLogs EmailLog[]

  // Resume imports
  resumeImports ResumeImport[]

  // Resume collaborations
  collaborations       ResumeCollaborator[]    @relation("UserCollaborations")
  authoredCollabComments CollaborationComment[] @relation("AuthoredCollabComments")
  skillProficiencies   UserSkillProficiency[]  @relation("UserSkillProficiencies")

  // RBAC: roles assigned via UserRoleAssignment, plus per-user
  // grants/suspensions via AccessModifier (see authorization.prisma).
  userRoles       UserRoleAssignment[]
  accessModifiers AccessModifier[]

  // Feed
  posts              Post[]           @relation("UserPosts")
  postComments       PostComment[]    @relation("UserComments")
  postLikes          PostLike[]       @relation("UserLikes")
  postBookmarks      PostBookmark[]   @relation("UserBookmarks")
  postReports        PostReport[]     @relation("UserReports")

  // Upload ownership (P0-005)
  uploads            Upload[]         @relation("UserUploads")

  // Notifications
  notifications      Notification[]   @relation("UserNotifications")
  notificationActors Notification[]   @relation("NotificationActors")

  // Jobs
  jobs               Job[]            @relation("UserJobs")

  // Identity tokens
  passwordResetTokens      PasswordResetToken[]
  emailVerificationTokens  EmailVerificationToken[]
  refreshTokens            RefreshToken[]
  loginAttempts            LoginAttempt[]
  webhooks                 WebhookConfig[] @relation("UserWebhooks")

  // Automation
  curatedBatches WeeklyCuratedBatch[] @relation("UserCuratedBatches")

  // Badges
  badges UserBadge[] @relation("UserBadges")

  // Success stories
  successStories SuccessStory[] @relation("UserSuccessStories")

  @@index([username])
  @@index([email])
  @@index([emailVerified])
  @@index([onboardingCompletedAt])
  @@index([primaryResumeId])
  @@index([isActive])
}

model UserPreferences {
  id     String @id @default(dbgenerated("uuidv7()"))
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Appearance (consolidated from User.bannerColor and User.palette)
  theme       String  @default("dark")
  palette     String  @default("ocean")
  bannerColor String?

  // Localization
  language   String @default("en")
  dateFormat String @default("MM/DD/YYYY")
  timezone   String @default("UTC")

  // Notifications
  emailNotifications Boolean         @default(true)
  resumeExpiryAlerts Boolean         @default(true)
  weeklyDigest       Boolean         @default(false)
  marketingEmails    Boolean         @default(false)
  emailMilestones    Boolean         @default(true)
  emailShareExpiring Boolean         @default(true)
  digestFrequency    DigestFrequency @default(WEEKLY)

  // Privacy
  profileVisibility      String  @default("private")
  showEmail              Boolean @default(false)
  showPhone              Boolean @default(false)
  allowSearchEngineIndex Boolean @default(false)

  // Export defaults
  defaultExportFormat  String  @default("pdf")
  includePhotoInExport Boolean @default(true)

  // How the user wants to apply to jobs. Drives the "Apply" button behaviour
  // and whether the weekly-curated / auto-apply workers pick this user up.
  applyMode ApplyMode @default(ONE_CLICK)

  // Opaque blob with the user's one-click-apply config (resumeId, cover
  // letter template, tailoring mode, attachment flags). Schema validated
  // at the route layer via Zod — backend doesn't interpret token strings
  // inside the template, only stores them.
  oneClickApplyConfig Json?

  applyCriteria UserApplyCriteria?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([applyMode])
}

// Optional per-user filters consumed by the Auto-Apply worker (and also used
// as defaults for the Weekly Curated picker). Separate table so we can extend
// it without touching UserPreferences on every new dimension.
model UserApplyCriteria {
  id            String          @id @default(dbgenerated("uuidv7()"))
  preferencesId String          @unique
  preferences   UserPreferences @relation(fields: [preferencesId], references: [id], onDelete: Cascade)

  minFit          Int?           // Skip jobs below this fit score (0–100).
  stacks          String[]       @default([])  // Preferred stacks / tech skills.
  seniorities     String[]       @default([])  // e.g. "Mid", "Senior", "Staff".
  remotePolicies  RemotePolicy[] @default([])
  paymentCurrencies PaymentCurrency[] @default([])
  minSalaryUsd    Int?           // Annual USD floor; null means "don't filter".
  defaultCover    String?        @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OnboardingProgress {
  id     String @id @default(dbgenerated("uuidv7()"))
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  currentStep    String   @default("welcome")
  completedSteps String[] @default([])
  username       String?

  // Form data (JSON)
  personalInfo        Json?
  professionalProfile Json?
  sections            Json?  // Generic sections array: [{ sectionTypeKey, items, noData }]
  templateSelection   Json?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  expiresAt DateTime? // TTL: Auto-cleanup for abandoned sessions (30 days)

  @@index([userId])
  @@index([expiresAt])
}

model AuditLog {
  id String @id @default(dbgenerated("uuidv7()"))

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  action     AuditAction
  entityType String // "User", "Resume", "Preferences", etc
  entityId   String // ID of affected resource

  // Changes snapshot
  changesBefore Json? // State before action
  changesAfter  Json? // State after action

  // Context metadata
  ipAddress String?
  userAgent String?
  metadata  Json? // Additional context (geo, referer, etc)

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@index([entityType, entityId])
  @@index([createdAt]) // For retention policy cleanup
}

// GDPR Compliance: Track ToS/Privacy Policy acceptance (#75)
model UserConsent {
  id String @id @default(dbgenerated("uuidv7()"))

  userId String
  user   User   @relation("UserConsents", fields: [userId], references: [id], onDelete: Cascade)

  documentType ConsentDocumentType
  version      String // e.g., "1.0.0", "1.1.0"

  acceptedAt DateTime @default(now())

  // Audit trail for compliance
  ipAddress String?
  userAgent String?

  @@unique([userId, documentType, version])
  @@index([userId, documentType])
  @@index([acceptedAt])
}
