// Authorization Models
//
// RBAC (Role-Based Access Control) — flat, two-role model:
// `user` and `admin`. Permissions live on roles via `RolePermission`.
//
// Account state (email-verified, onboarding-completed) lives on
// `User` as timestamps — see prisma/schema/user.prisma.
//
// Per-user grants/suspensions (e.g., "suspend email-verified for 14
// days") live in `AccessModifier`, which can carry an `endsAt` and
// override either a state column or a permission-via-role.

/// Permission defines a single atomic action on a resource.
/// Example: "resume:create", "user:delete", "theme:approve"
model Permission {
  id String @id @default(dbgenerated("uuidv7()"))

  /// Resource being accessed (e.g., "resume", "user", "theme")
  resource String

  /// Action being performed (e.g., "create", "read", "update", "delete", "approve")
  action String

  /// Human-readable description of what this permission allows
  description String?

  /// Whether this permission is a system permission (cannot be deleted)
  isSystem Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  roles    RolePermission[]
  modifier AccessModifier[]

  @@unique([resource, action])
  @@index([resource])
  @@index([action])
}

/// Role is a named collection of permissions. The system has only two:
/// `user` (job-seeker capabilities) and `admin` (auto-grant of every
/// Permission enum value).
model Role {
  id String @id @default(dbgenerated("uuidv7()"))

  /// Unique role name. System uses 'user' and 'admin'.
  name String @unique

  /// Human-readable display name
  displayName String

  /// Description of what this role represents
  description String?

  /// Whether this is a system role (cannot be deleted)
  isSystem Boolean @default(false)

  /// Priority for conflict resolution (higher = more precedence)
  priority Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  permissions RolePermission[]
  users       UserRoleAssignment[]

  @@index([name])
  @@index([priority])
}

// ============================================================================
// Junction Tables (Many-to-Many Relationships)
// ============================================================================

/// Assigns permissions to roles
model RolePermission {
  id           String @id @default(dbgenerated("uuidv7()"))
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  /// Who assigned this permission
  assignedBy String?
  assignedAt DateTime @default(now())

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

/// Assigns roles to users
model UserRoleAssignment {
  id     String @id @default(dbgenerated("uuidv7()"))
  userId String
  roleId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  /// Who assigned this role
  assignedBy String?
  assignedAt DateTime @default(now())

  /// Optional expiration for temporary roles
  expiresAt DateTime?

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@index([expiresAt])
}

// ============================================================================
// Access modifiers
// ============================================================================

enum ModifierEffect {
  /// Suspend a state or revoke a permission for the duration window.
  DENY
  /// Grant a permission (or restore a state) for the duration window.
  GRANT
}

enum ModifierType {
  /// Suspends `User.emailVerifiedAt` even if the timestamp is set.
  SUSPEND_EMAIL_VERIFIED
  /// Suspends `User.onboardingCompletedAt` even if the timestamp is set.
  SUSPEND_ONBOARDING
  /// Suspends a role assignment without removing the row.
  SUSPEND_ROLE_USER
  /// Suspends a role assignment without removing the row.
  SUSPEND_ROLE_ADMIN
  /// Grants an individual permission outside any role (e.g., beta features).
  GRANT_PERMISSION
}

/// AccessModifier overlays state/role/permission with a time-bounded,
/// audit-friendly suspension or grant. The permission gate composes
/// modifiers on top of `User.<event>At` and `UserRoleAssignment` to
/// decide if a request is allowed.
///
/// Modifier rows are immutable history: revoke by setting `revokedAt`,
/// never delete. Anyone querying audit can replay activations and
/// revocations from the same table.
model AccessModifier {
  id     String @id @default(dbgenerated("uuidv7()"))
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// What is being suspended/granted.
  modifierType ModifierType
  /// DENY (suspends) or GRANT (adds).
  effect       ModifierEffect

  /// For GRANT_PERMISSION: which permission is granted.
  permissionId String?
  permission   Permission? @relation(fields: [permissionId], references: [id], onDelete: SetNull)

  /// Free-text reason audit log surfaces ("suspeita de comprometimento", "beta cohort A").
  reason String

  /// When the modifier becomes active.
  startsAt DateTime  @default(now())
  /// When the modifier expires. `null` = active until revoked.
  endsAt   DateTime?

  /// Who applied the modifier (admin userId).
  createdBy String

  /// When the modifier was revoked. `null` = still in effect within window.
  revokedAt DateTime?
  /// Who revoked the modifier (admin userId).
  revokedBy String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userId, endsAt, revokedAt])
  @@index([modifierType])
  @@index([permissionId])
}
