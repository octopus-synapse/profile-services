// Jobs: Job listings posted by users

model Job {
  id       String  @id @default(dbgenerated("uuidv7()"))
  // P0-#26: `authorId` becomes nullable so the FK can `SetNull` on user
  // delete. The Job itself survives erasure (analytics + outside candidate
  // visibility) but the authorship attribution is anonymised.
  authorId String?
  author   User?   @relation("UserJobs", fields: [authorId], references: [id], onDelete: SetNull)

  title        String
  company      String
  location     String?
  jobType      JobType
  description  String   @db.Text
  requirements String[]
  skills       String[]
  salaryRange  String?
  applyUrl     String?

  // Structured currency/remote/language fields. Free-form `salaryRange` stays
  // (we still display it verbatim); these unlock server-side filtering and
  // let Fit Score reason about English requirements without NLP on every job.
  paymentCurrency PaymentCurrency?
  remotePolicy    RemotePolicy?
  minEnglishLevel EnglishLevel?

  // Structured requirements + AI enrichment (job-match context).
  // `requirementsStructured` holds the recruiter-filled slots; the AI-enriched
  // payload is kept separately so we can diff/audit what the model added.
  requirementsStructured   Json?
  requirementsEnrichedByAi Json?
  enrichedAt               DateTime?
  enrichedBy               String?

  // Whether the recruiter has captured the job's cultural/behavioural profile
  // (JobFitProfile). Used to gate "Match Score" availability recruiter-side.
  culturalProfileCaptured Boolean @default(false)

  // Semantic Matcher input: job description embedding (pgvector, 1536 dims
  // — text-embedding-3-small). Stored here so Match Score sub-compute can
  // reuse it without re-calling OpenAI on every request.
  embeddingVector Unsupported("vector(1536)")?

  isActive  Boolean   @default(true)
  expiresAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookmarks    JobBookmark[]
  applications JobApplication[]

  // Scoring subsystem — recruiter-owned fit profile (one per job).
  fitProfile JobFitProfile?

  // Resume versions tailored *for* this job. Populated by the tailor pipeline
  // so we can (a) avoid re-running the LLM when a tailored version already
  // exists and (b) show "X users tailored their CV for this job" analytics.
  tailoredResumeVersions ResumeVersion[] @relation("JobTailoredResumeVersions")

  // Automation — curated items pointing at this job.
  curatedItems WeeklyCuratedItem[] @relation("JobCuratedItems")

  @@index([authorId])
  @@index([jobType, createdAt])
  @@index([isActive, createdAt])
  // P2-#35 (audit deferred): the three composite indexes below look
  // like over-indexing at first glance, but each one services a
  // distinct filter combination used by the jobs board (currency
  // filter, remote-policy filter, active-only feed). Consolidating
  // would need an `EXPLAIN ANALYZE` pass against prod-shaped data —
  // see the BUG_REPORT P2-#35 follow-up. The implicit `isActive`
  // membership means dropping `[isActive, createdAt]` would also
  // require a partial index on the others; not a free swap.
  @@index([paymentCurrency, isActive, createdAt])
  @@index([remotePolicy, isActive, createdAt])
}

model JobBookmark {
  id     String @id @default(dbgenerated("uuidv7()"))
  jobId  String
  job    Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  userId String
  // P0-#25: real FK so the row cascades when the user is erased (LGPD).
  user   User   @relation("UserBookmarks", fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([jobId, userId])
  @@index([userId, createdAt])
}

model JobApplication {
  id     String @id @default(dbgenerated("uuidv7()"))
  jobId  String
  job    Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  userId String
  // P0-#25: real FK so the row cascades when the user is erased (LGPD).
  user   User   @relation("UserApplications", fields: [userId], references: [id], onDelete: Cascade)

  coverLetter String? @db.Text
  resumeId    String?

  // When the auto-apply worker sends an AI-tailored CV the version id is
  // stored here so the tracker UI can render "you applied with this
  // tailored variant" and downstream analytics can measure whether
  // tailored versions respond at a higher rate than the master.
  tailoredVersionId String?

  status    JobApplicationStatus @default(SUBMITTED)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  // Timeline events — ordered by `occurredAt`. Used by the tracker service to
  // render "enviada → visualizada → entrevista → oferta/silêncio" and to
  // compute per-company response percentiles.
  events JobApplicationEvent[]

  @@unique([jobId, userId])
  @@index([userId, createdAt])
  @@index([jobId, createdAt])
}

enum JobApplicationStatus {
  SUBMITTED
  VIEWED
  REJECTED
  ACCEPTED
  WITHDRAWN
}

// External listings ingested daily from the JSearch aggregator (RapidAPI).
// Deliberately decoupled from `Job`: no FKs, no fit-score, no recruiter
// authorship — these rows are a read-only mirror of third-party postings
// with a 30-day retention sweep. `externalId` is JSearch's job_id;
// `dedupHash` (normalized title|company) absorbs the same vacancy being
// re-listed under a different publisher/job_id.
model ExternalJobListing {
  id             String    @id @default(dbgenerated("uuidv7()"))
  externalId     String    @unique
  dedupHash      String
  title          String
  company        String
  location       String?
  // Raw upstream `job_is_remote` flag, kept as provenance; `workMode`
  // is the filterable signal (HYBRID is inferred — see
  // `domain/services/derive-work-mode.ts`).
  isRemote       Boolean   @default(false)
  workMode       RemotePolicy @default(ONSITE)
  employmentType JobType?
  applyUrl       String
  publisher      String?
  // Truncated at ingestion (5000 chars) — `raw` stores the rest of the
  // upstream payload *without* the description to keep JSONB rows sane.
  description    String?   @db.Text
  // Often null for BR results: JSearch returns only a relative
  // "há 15 horas" string for most Brazilian postings.
  postedAt       DateTime?
  fetchedAt      DateTime
  sourceQuery    String
  raw            Json

  @@index([dedupHash])
  @@index([fetchedAt])
  @@index([postedAt])
  @@index([workMode, postedAt])
  @@index([employmentType, postedAt])
}

// User-saved external listings. `ExternalJobListing` rows are swept
// after 30 days, so the display fields are snapshotted at save time —
// a saved job must outlive the mirror row it came from. No FK to the
// listing on purpose; `externalId` keeps the identity for the
// `isSaved` annotation while the listing is still around.
model SavedExternalJob {
  id     String @id @default(dbgenerated("uuidv7()"))
  userId String
  user   User   @relation("UserSavedExternalJobs", fields: [userId], references: [id], onDelete: Cascade)

  externalId String

  // ---- snapshot of the listing's display fields at save time
  title          String
  company        String
  location       String?
  isRemote       Boolean
  workMode       RemotePolicy
  employmentType JobType?
  applyUrl       String
  publisher      String?
  description    String?   @db.Text
  postedAt       DateTime?
  fetchedAt      DateTime

  createdAt DateTime @default(now())

  @@unique([userId, externalId])
  @@index([userId, createdAt])
}
