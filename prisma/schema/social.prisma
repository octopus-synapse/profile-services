// Social Features Schema - Follow and Activity models

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  follower    User     @relation("Followers", fields: [followerId], references: [id], onDelete: Cascade)
  followingId String
  following   User     @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
  @@index([createdAt])
}

model Activity {
  id         String       @id @default(cuid())
  userId     String
  user       User         @relation("UserActivities", fields: [userId], references: [id], onDelete: Cascade)
  type       ActivityType
  metadata   Json?
  entityId   String? // ID of related entity (resume, theme, etc.)
  entityType String? // Type of related entity
  createdAt  DateTime     @default(now())

  @@index([userId, createdAt])
  @@index([type, createdAt])
  @@index([entityId])
}

model Connection {
  id          String           @id @default(cuid())
  requesterId String
  requester   User             @relation("SentConnections", fields: [requesterId], references: [id], onDelete: Cascade)
  targetId    String
  target      User             @relation("ReceivedConnections", fields: [targetId], references: [id], onDelete: Cascade)
  status      ConnectionStatus @default(PENDING)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([requesterId, targetId])
  @@index([requesterId, status])
  @@index([targetId, status])
}

enum ConnectionStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model SkillEndorsement {
  id              String @id @default(cuid())
  endorsedUserId  String
  skillName       String
  endorserUserId  String

  createdAt DateTime @default(now())

  @@unique([endorsedUserId, skillName, endorserUserId])
  @@index([endorsedUserId, skillName])
  @@index([endorserUserId])
}

enum SkillProficiency {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

// Self-declared proficiency per skill. Orthogonal to endorsements — the
// former is "how I see myself", the latter is "what peers vouched for".
model UserSkillProficiency {
  id          String           @id @default(cuid())
  userId      String
  user        User             @relation("UserSkillProficiencies", fields: [userId], references: [id], onDelete: Cascade)
  skillName   String
  proficiency SkillProficiency @default(INTERMEDIATE)
  yearsOfExperience Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, skillName])
  @@index([userId])
  @@index([skillName])
}

// One row per (user, skill, quarter) that the decay scan has nagged.
// Keeps the cron from re-notifying the same skill every week and lets
// analytics see which skills decay most often.
model SkillDecayLog {
  id               String   @id @default(cuid())
  userId           String
  skillName        String
  quarterKey       String // YYYY-Qn
  daysSinceTouched Int
  emittedAt        DateTime @default(now())

  @@unique([userId, skillName, quarterKey])
  @@index([userId])
  @@index([quarterKey])
  @@map("skill_decay_logs")
}
