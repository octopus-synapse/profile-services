// Notifications: In-app notifications for user engagement

model Notification {
  id     String @id @default(dbgenerated("uuidv7()"))
  userId String
  user   User   @relation("UserNotifications", fields: [userId], references: [id])

  type    NotificationType
  actorId String?
  actor   User?            @relation("NotificationActors", fields: [actorId], references: [id])

  entityType String? // "post", "comment", "connection"
  entityId   String?

  message       String
  /**
   * Stable i18n key (e.g. "notification.application_stale") so the same
   * notification can be re-rendered in any language without hitting the
   * backend again. The literal `message` above stays as a fallback for
   * old rows and for plain-text channels (push, SMS).
   */
  messageKey    String?
  messageParams Json?
  read          Boolean @default(false)

  // Email delivery tracking — null means "never sent", value means "sent at that time".
  emailSentAt       DateTime?
  emailDigestSentAt DateTime?

  createdAt DateTime @default(now())

  @@index([userId, read, createdAt])
  @@index([userId, createdAt])
  @@index([emailDigestSentAt])
}

model NotificationPreference {
  id            String            @id @default(dbgenerated("uuidv7()"))
  userId        String
  type          NotificationType
  // Master switch for this type (legacy meaning + in-app presence).
  enabled       Boolean           @default(true)
  // Per-channel toggles. `enabled` stays the master switch; the per-channel
  // flags let a user keep, say, in-app on while turning email/push off.
  inAppEnabled  Boolean           @default(true)
  // Per-type email delivery override. null/true = email on each event; false = never email.
  emailEnabled  Boolean           @default(true)
  pushEnabled   Boolean           @default(false)
  // Instant vs. batched delivery — 'INSTANT' sends per-event, 'DAILY' rolls up in a digest.
  emailDelivery EmailDeliveryMode @default(INSTANT)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, type])
  @@index([userId])
}

// A device registered to receive Expo push notifications. One row per
// physical device (keyed by its Expo push token); a user may have many.
model PushDevice {
  id            String         @id @default(dbgenerated("uuidv7()"))
  userId        String
  user          User           @relation("UserPushDevices", fields: [userId], references: [id], onDelete: Cascade)
  expoPushToken String         @unique
  platform      DevicePlatform
  createdAt     DateTime       @default(now())
  lastSeenAt    DateTime?

  @@index([userId])
}

enum EmailDeliveryMode {
  INSTANT
  DAILY
  WEEKLY
  OFF
}

// One row per user per ISO-week that received the weekly digest.
// Guarantees the cron job is idempotent: a retry after a partial failure
// cannot double-send.
model UserWeeklyDigestLog {
  id      String   @id @default(dbgenerated("uuidv7()"))
  userId  String
  weekKey String // YYYY-Www format (ISO-8601 week)
  sentAt  DateTime @default(now())

  @@unique([userId, weekKey])
  @@index([weekKey])
  @@index([userId])
  @@map("user_weekly_digest_logs")
}

// One row per (user, reminder-window, day) for the fit-profile expiry
// reminder fanout — DB-level idempotency (Wave 1.3 P1 #29). The Redis
// flag in `ReminderStatePort` is fast-path dedup; this table is the
// authoritative lock that survives Redis flushes / multi-instance races.
// `sentDate` is a date-only string (YYYY-MM-DD) so two reminders within
// the same calendar day collapse onto one row regardless of clock skew.
model FitProfileReminderLog {
  id       String   @id @default(dbgenerated("uuidv7()"))
  userId   String
  daysLeft Int // 7 / 3 / 1 — the window the reminder belongs to
  sentDate String // YYYY-MM-DD
  sentAt   DateTime @default(now())

  @@unique([userId, daysLeft, sentDate])
  @@index([sentDate])
  @@map("fit_profile_reminder_logs")
}
