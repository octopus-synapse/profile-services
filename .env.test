# Test Environment Configuration
NODE_ENV="test"
PORT=3001
LOG_LEVEL="error"

# Test Database (use a separate test database)
# Uses docker-compose.test.yml ports: postgres:5433, redis:6380
# `connection_limit=50` raises the Prisma pool from the default 10
# so `--concurrent --max-concurrency=8` × multiple shards don't
# starve on connections.
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/profile_test?schema=public&connection_limit=50"

# JWT
JWT_SECRET="test-secret-key-for-integration-tests-min-32-chars"
JWT_EXPIRATION="7d"

# Drop bcrypt cost from 12 → 4 in tests so signup/login/admin-seed
# don't pay ~80ms × N hashes. Same algorithm, fewer rounds.
BCRYPT_COST=4

# Redis (for testing)
REDIS_HOST="localhost"
REDIS_PORT=6380
REDIS_PASSWORD=""

# Rate limiting (enabled for security tests)
RATE_LIMIT_ENABLED=true

# MinIO S3-compatible storage (optional - disabled for tests)
MINIO_ENDPOINT=""
MINIO_ACCESS_KEY=""
MINIO_SECRET_KEY=""
MINIO_BUCKET=""

# Frontend
FRONTEND_URL="http://localhost:3000"
